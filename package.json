{
  "name": "bmw-estimate-check",
  "version": "1.0.0",
  "private": true,
  "description": "Compare BMW mechanic repair estimates against OEM and aftermarket part prices, then buy the parts online.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:local": "tsx scripts/dev-db.ts",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "test:flows": "tsx --conditions=react-server scripts/test-flows.ts",
    "typecheck": "tsc --noEmit"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "@vercel/blob": "^2.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.4.7",
    "lucide-react": "^0.475.0",
    "next": "^15.2.3",
    "openai": "^4.86.1",
    "pdf-parse": "^1.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "sharp": "^0.35.3",
    "stripe": "^22.3.2",
    "tailwind-merge": "^3.0.2",
    "tesseract.js": "^7.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.9",
    "@types/node": "^22.13.5",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "embedded-postgres": "^18.4.0-beta.17",
    "prisma": "^6.5.0",
    "tailwindcss": "^4.0.9",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
