# ---------------------------------------------------------------------------
# BMW Estimate Check — environment variables
# Copy to .env. The defaults below work with zero external accounts.
# ---------------------------------------------------------------------------

# PostgreSQL connection string.
# Free local option (no install needed): run `npm run db:local` and use:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bmw_estimate_check?schema=public"

# App URL (no trailing slash). Used for SEO metadata and the sitemap.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- AI estimate parsing (OPTIONAL — free options available) -----------------
# Leave OPENAI_API_KEY empty to use the built-in free heuristic parser
# (pattern matching on PDF text — no AI account needed, photos unsupported).
#
# Any OpenAI-compatible provider works. Free options:
#
#   Google Gemini (free tier, no credit card — https://aistudio.google.com/apikey):
#     OPENAI_API_KEY="<your AI Studio key>"
#     OPENAI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
#     OPENAI_MODEL="gemini-2.5-flash"
#
#   Groq (free tier — https://console.groq.com/keys):
#     OPENAI_API_KEY="gsk_..."
#     OPENAI_BASE_URL="https://api.groq.com/openai/v1"
#     OPENAI_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"
#
#   Ollama (100% local and free — https://ollama.com):
#     OPENAI_API_KEY="ollama"
#     OPENAI_BASE_URL="http://localhost:11434/v1"
#     OPENAI_MODEL="llama3.2-vision"
#
#   OpenAI (paid — https://platform.openai.com/api-keys):
#     OPENAI_API_KEY="sk-..."
#     OPENAI_MODEL="gpt-5.5"
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
OPENAI_MODEL="gpt-5.5"

# --- Make money (affiliate IDs — all free to join) ---------------------------
# Buy buttons already work without these. Once you add your IDs, purchases
# through those links pay you a commission.
#
# Amazon Associates (https://affiliate-program.amazon.com/):
#   NEXT_PUBLIC_AMAZON_ASSOCIATE_TAG="yourtag-20"
#
# eBay Partner Network (https://partnernetwork.ebay.com/):
#   NEXT_PUBLIC_EBAY_CAMPAIGN_ID="5338xxxxxx"
#
# FCP Euro via Impact (ask FCP for their Impact / shareasale link; paste the
# click/tracking ID portion):
#   NEXT_PUBLIC_FCP_EURO_CLICK_ID="xxxxx"
#
# RockAuto links work for shoppers today; their affiliate program (when open)
# is usually via Impact — add custom tracking later if approved.
NEXT_PUBLIC_AMAZON_ASSOCIATE_TAG=""
NEXT_PUBLIC_EBAY_CAMPAIGN_ID=""
NEXT_PUBLIC_FCP_EURO_CLICK_ID=""

# --- Take real card payments (Stripe — free to create an account) ------------
# Signup: https://dashboard.stripe.com/register  (no monthly fee)
# Test keys (fake cards, no real money): https://dashboard.stripe.com/test/apikeys
# Live keys (real money): switch to "Live mode" in the same dashboard.
#
# You do NOT pay Stripe up front. They take ~2.9% + $0.30 only when a
# customer successfully pays you. Test mode charges nothing.
#
# Without these keys, checkout still works in demo mode (no card charged).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Optional publishable key if you add Stripe.js later:
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- Auto dropship (customer pays you → suppliers ship — you keep the margin)
# Flow: Stripe payment → app auto-dispatches the order to Order Desk and/or
# your webhook → supplier buys + ships to the customer. You never click Buy.
#
# Option A (recommended): Order Desk (orderdesk.com) — connect Amazon / other
# suppliers once, then every paid order is pushed automatically.
ORDERDESK_STORE_ID=""
ORDERDESK_API_KEY=""
#
# Option B: Make.com / Zapier / n8n Catch Hook URL — POST receives full JSON
# (parts, OEM #s, ship-to, buy URLs). Map it to Amazon Business / PartsTech / VA.
FULFILLMENT_WEBHOOK_URL=""
FULFILLMENT_WEBHOOK_SECRET="change-me-to-a-long-random-string"
#
# Backup only: email a buy sheet to YOU (never the customer) if auto-dispatch fails.
FULFILLMENT_EMAIL=""
#
# When a package ships, POST tracking:
#   POST https://YOUR_APP/api/fulfillment/tracking
#   { "orderId": "...", "trackingNumber": "1Z...", "secret": "<FULFILLMENT_WEBHOOK_SECRET>" }