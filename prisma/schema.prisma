generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EstimateStatus {
  UPLOADED
  PROCESSING
  PARSED
  FAILED
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ShippingDestination {
  HOME
  MECHANIC
}

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  SPECIAL_ORDER
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  vehicles  Vehicle[]
  estimates Estimate[]
  carts     Cart[]
  orders    Order[]
  mechanics Mechanic[]
  emails    EmailNotification[]
}

model Mechanic {
  id             String   @id @default(cuid())
  userId         String
  shopName       String
  contactPerson  String?
  address        String
  city           String
  state          String
  zip            String
  phone          String
  notes          String?
  isFavorite     Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
}

model EmailNotification {
  id        String   @id @default(cuid())
  userId    String
  orderId   String?
  type      String
  subject   String
  body      String   @db.Text
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([orderId])
}

model Vehicle {
  id        String   @id @default(cuid())
  userId    String
  year      Int
  make      String   @default("BMW")
  model     String
  trim      String?
  engine    String?
  vin       String?
  createdAt DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  estimates Estimate[]

  @@index([userId])
}

model Estimate {
  id               String         @id @default(cuid())
  userId           String
  vehicleId        String
  originalFileUrl  String
  originalFileType String         @default("application/pdf")
  extractedText    String?        @db.Text
  mechanicShopName String?
  mechanicTotal    Float?
  laborTotal       Float?
  status           EstimateStatus @default(UPLOADED)
  errorMessage     String?
  createdAt        DateTime       @default(now())

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle     Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  items       EstimateItem[]
  comparisons Comparison[]

  @@index([userId])
}

model EstimateItem {
  id            String  @id @default(cuid())
  estimateId    String
  description   String
  quantity      Int     @default(1)
  mechanicPrice Float
  oemPartNumber String?

  estimate    Estimate     @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  comparisons Comparison[]

  @@index([estimateId])
}

model CatalogPart {
  id               String      @id @default(cuid())
  sku              String      @unique
  brand            String
  name             String
  description      String      @db.Text
  category         String      @default("General")
  oemNumbers       String[]    @default([])
  compatibleModels String[]    @default([])
  compatibleYears  Int[]       @default([])
  price            Float
  imageUrl         String?
  stockStatus      StockStatus @default(IN_STOCK)
  createdAt        DateTime    @default(now())

  comparisons Comparison[]
  cartItems   CartItem[]
  orderItems  OrderItem[]

  @@index([category])
  @@index([brand])
}

model Comparison {
  id             String  @id @default(cuid())
  estimateId     String
  estimateItemId String?
  catalogPartId  String
  mechanicPrice  Float
  ourPrice       Float
  savings        Float
  matchMethod    String  @default("SEMANTIC") // OEM_NUMBER | SEMANTIC | MANUAL
  matchScore     Float   @default(0)

  estimate     Estimate      @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  estimateItem EstimateItem? @relation(fields: [estimateItemId], references: [id], onDelete: SetNull)
  catalogPart  CatalogPart   @relation(fields: [catalogPartId], references: [id], onDelete: Cascade)

  @@index([estimateId])
}

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model CartItem {
  id            String @id @default(cuid())
  cartId        String
  catalogPartId String
  quantity      Int    @default(1)

  cart        Cart        @relation(fields: [cartId], references: [id], onDelete: Cascade)
  catalogPart CatalogPart @relation(fields: [catalogPartId], references: [id], onDelete: Cascade)

  @@unique([cartId, catalogPartId])
}

model Order {
  id              String              @id @default(cuid())
  userId          String
  stripeSessionId String?             @unique
  subtotal        Float
  shipping        Float               @default(0)
  tax             Float               @default(0)
  total           Float
  status          OrderStatus         @default(PENDING)
  shippingDestination ShippingDestination @default(HOME)
  shippingName    String?
  shippingAddress String?
  shippingCity    String?
  shippingState   String?
  shippingZip     String?
  shippingCountry String?
  mechanicId      String?
  mechanicShopName String?
  mechanicContact  String?
  mechanicPhone    String?
  appointmentDate  DateTime?
  appointmentTime  String?
  repairNotes      String?            @db.Text
  trackingNumber   String?
  estimatedDelivery DateTime?
  shippedAt        DateTime?
  deliveredAt      DateTime?
  createdAt       DateTime            @default(now())

  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  mechanic Mechanic?            @relation(fields: [mechanicId], references: [id], onDelete: SetNull)
  items    OrderItem[]
  emails   EmailNotification[]

  @@index([userId])
  @@index([status])
  @@index([mechanicId])
}

model OrderItem {
  id            String @id @default(cuid())
  orderId       String
  catalogPartId String
  quantity      Int    @default(1)
  unitPrice     Float

  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  catalogPart CatalogPart @relation(fields: [catalogPartId], references: [id])

  @@index([orderId])
}
